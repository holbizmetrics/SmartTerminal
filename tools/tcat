#!/usr/bin/env python3
"""tcat — print a file as an OSC 1338 inline-media escape sequence.

Emits an OSC 1338 sequence to stdout that SmartTerminal (or any terminal
supporting the spec) renders inline. Non-supporting terminals strip the
sequence silently.

SPEC: SmartTerminal/docs/OSC-1338-SPEC.md
Usage:
  tcat file.mmd                 # auto-detect type from extension
  tcat --type mermaid file.txt  # override type
  tcat --type mermaid <<<'graph TD; A-->B'   # read from stdin
"""
import argparse
import base64
import mimetypes
import sys
from pathlib import Path

EXT_TYPE = {
    ".mmd": "mermaid", ".mermaid": "mermaid",
    ".svg": "svg",
    ".png": "image", ".jpg": "image", ".jpeg": "image",
    ".gif": "image", ".webp": "image",
    ".mp3": "audio", ".ogg": "audio", ".wav": "audio",
}
LIMITS = {"mermaid": 65536, "svg": 262144, "audio": 4194304, "image": 2097152}
TEXT_TYPES = {"mermaid", "svg"}


def detect_type(path: Path) -> str | None:
    return EXT_TYPE.get(path.suffix.lower())


MIME_ALIASES = {"audio/mp3": "audio/mpeg"}  # normalize Windows non-IANA defaults


def detect_mime(path: Path, media_type: str) -> str:
    if media_type in TEXT_TYPES:
        return ""
    guess, _ = mimetypes.guess_type(path.name)
    if guess:
        return MIME_ALIASES.get(guess, guess)
    return {"audio": "audio/mpeg", "image": "image/png"}[media_type]


def emit(media_type: str, payload: bytes, mime: str = "") -> bytes:
    if len(payload) > LIMITS[media_type]:
        raise SystemExit(
            f"tcat: payload {len(payload)} B exceeds {media_type} limit "
            f"{LIMITS[media_type]} B"
        )
    b64 = base64.standard_b64encode(payload).decode("ascii")
    params = [f"type={media_type}", f"data={b64}"]
    if mime:
        params.insert(1, f"mime={mime}")
    body = ";".join(params)
    return b"\x1b]1338;" + body.encode("ascii") + b"\x07"


def main(argv: list[str]) -> int:
    p = argparse.ArgumentParser(prog="tcat", description=__doc__.splitlines()[0])
    p.add_argument("file", nargs="?", help="file to emit; omit to read stdin")
    p.add_argument("--type", choices=sorted(LIMITS.keys()),
                   help="media type (auto-detected from extension if omitted)")
    p.add_argument("--mime", help="MIME type override (audio/image only)")
    args = p.parse_args(argv)

    if args.file:
        path = Path(args.file)
        if not path.exists():
            print(f"tcat: no such file: {path}", file=sys.stderr)
            return 1
        payload = path.read_bytes()
        media_type = args.type or detect_type(path)
        if not media_type:
            print(f"tcat: unknown extension {path.suffix!r}; pass --type",
                  file=sys.stderr)
            return 2
        mime = args.mime or detect_mime(path, media_type)
    else:
        if not args.type:
            print("tcat: --type required when reading from stdin", file=sys.stderr)
            return 2
        payload = sys.stdin.buffer.read()
        media_type = args.type
        mime = args.mime or ("" if media_type in TEXT_TYPES
                             else {"audio": "audio/mpeg", "image": "image/png"}[media_type])

    sys.stdout.buffer.write(emit(media_type, payload, mime))
    sys.stdout.buffer.flush()
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
