<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    
    <!-- Dark Theme Colors -->
    <Color x:Key="Primary">#4CAF50</Color>
    <Color x:Key="PrimaryDark">#388E3C</Color>
    <Color x:Key="PrimaryLight">#C8E6C9</Color>
    <Color x:Key="Accent">#2196F3</Color>
    
    <Color x:Key="Background">#1e1e1e</Color>
    <Color x:Key="Surface">#2d2d2d</Color>
    <Color x:Key="SurfaceLight">#3d3d3d</Color>
    
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#888888</Color>
    <Color x:Key="TextDisabled">#555555</Color>
    
    <Color x:Key="Error">#f44336</Color>
    <Color x:Key="Warning">#ff9800</Color>
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Info">#2196F3</Color>

    <!-- Semantic Colors -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

</ResourceDictionary>
