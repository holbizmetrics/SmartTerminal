<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- targetSdkVersion 28 — DELIBERATE (the Termux trick): SELinux only allows
         executing runtime-downloaded binaries from app storage for apps targeting
         SDK <= 28. This is the load-bearing enabler for stpkg (runtime package
         installs: git, python, ...). Trade-off: relaxes our own sandbox + pins
         legacy storage/permission behaviors; acceptable for a side-loaded personal
         power-tool, NOT Play-Store compatible. See ROADMAP 2026-07-07. -->
    <uses-sdk android:targetSdkVersion="28" />

    <!-- Internet for xterm.js CDN loading (first launch) and future package management -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Wake lock to prevent terminal sessions from dying -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Foreground service for session persistence -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Vibrate for terminal bell -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Storage access for /sdcard/ -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:extractNativeLibs="true"
        android:networkSecurityConfig="@xml/network_security_config">
    </application>

</manifest>
